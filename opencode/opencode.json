{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "grep *": "allow",
      "which *": "allow",
      "cat *": "allow",
      "tail *": "allow",
      "head *": "allow",
      "find *": "allow",
      "sed *": "allow",
      "ls *": "allow",
      "ls": "allow",
      "echo *": "allow",
      "file *": "allow",
      "mkdir *": "allow",
      "cargo fmt *": "allow",
      "cargo clippy *": "allow",
      "cargo build *": "allow",
      "cargo test *": "allow",
      "cargo run *": "allow",
      "cargo check *": "allow",
      "sqlite3 *": "allow",
      "printf *": "allow",
      "nvidia-smi *": "allow",
      "glob *": "allow",
      "fetch *": "allow",
      "curl *": "allow",
    },
    "edit": "allow"
  },
  "compaction": {
    "auto": false,
    "prune": true
  },
  "provider": {
    "nvidia": {
      "models": {
        "z-ai/glm5": {
          "thinking": true
        }
      }
    }
  },
  "agent": {
    "title": {
      "model": "nvidia/moonshotai/kimi-k2-instruct-0905"
    },
    "summary": {
      "model": "nvidia/moonshotai/kimi-k2-instruct-0905"
    },
    "compaction": {
      "model": "nvidia/moonshotai/kimi-k2-instruct-0905"
    },
    "plan": {
      "model": "openai/gpt-5.4"
    },
    "build": {
      "model": "openai/gpt-5.3-codex"
    },
    "explore": {
      "model": "nvidia/moonshotai/kimi-k2-instruct-0905"
    }
  }
}
