{
  "$schema": "https://opencode.ai/config.json",
  "theme": "tokyonight-transparent",
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "grep *": "allow",
      "which *": "allow",
      "cat *": "allow",
      "tail *": "allow",
      "head *": "allow",
      "find *": "allow",
      "sed *": "allow",
      "ls *": "allow",
      "ls": "allow",
      "echo *": "allow",
      "file *": "allow",
      "mkdir *": "allow",
      "cargo fmt *": "allow",
      "cargo clippy *": "allow",
      "cargo build *": "allow",
      "cargo test *": "allow",
      "cargo run *": "allow",
      "cargo check *": "allow",
      "sqlite3 *": "allow",
      "printf *": "allow",
      "nvidia-smi *": "allow",
    },
    "edit": "allow"
  },
  "compaction": {
    "auto": false,
    "prune": true
  },
  "agent": {
    "title": {
      "model": "github-copilot/gpt-5-mini"
    },
    "summary": {
      "model": "github-copilot/gpt-5-mini"
    },
    "compaction": {
      "model": "github-copilot/gpt-5-mini"
    },
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "build": {
      "model": "github-copilot/claude-opus-4.6"
    },
    "explore": {
      "model": "github-copilot/gpt-5-mini"
    }
  }
}
