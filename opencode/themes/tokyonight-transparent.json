{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "tn_bg":        "#1a1b2e",
    "tn_bg_dark":   "#16161e",
    "tn_bg_panel":  "#1f2335",
    "tn_bg_elem":   "#24283b",
    "tn_border":    "#292e42",
    "tn_border_hl": "#3b4261",
    "tn_fg": "#ffffff",
    "tn_fg_dark":   "#565f89",
    "tn_blue":      "#7aa2f7",
    "tn_blue_dark": "#3d59a1",
    "tn_cyan":      "#7dcfff",
    "tn_teal":      "#1abc9c",
    "tn_green":     "#9ece6a",
    "tn_yellow":    "#e0af68",
    "tn_orange":    "#ff9e64",
    "tn_red":       "#f7768e",
    "tn_magenta":   "#bb9af7",
    "tn_purple":    "#9d7cd8"
  },
  "theme": {
    "primary":      { "dark": "tn_blue",    "light": "tn_blue_dark" },
    "secondary":    { "dark": "tn_magenta", "light": "tn_purple" },
    "accent":       { "dark": "tn_cyan",    "light": "tn_teal" },
    "error":        { "dark": "tn_red",     "light": "tn_red" },
    "warning":      { "dark": "tn_yellow",  "light": "tn_yellow" },
    "success":      { "dark": "tn_green",   "light": "tn_green" },
    "info":         { "dark": "tn_cyan",    "light": "tn_blue_dark" },
    "text": { "dark": "tn_fg", "light": "tn_fg" },
    "textMuted":    { "dark": "tn_fg_dark", "light": "tn_border_hl" },
    "background":        "none",
    "backgroundPanel":   "none",
    "backgroundElement": { "dark": "tn_bg_elem", "light": "tn_border" },
    "border":       { "dark": "tn_border",    "light": "tn_border" },
    "borderActive": { "dark": "tn_border_hl", "light": "tn_border_hl" },
    "borderSubtle": { "dark": "tn_border",    "light": "tn_border" },
    "diffAdded":           { "dark": "tn_green",  "light": "tn_green" },
    "diffRemoved":         { "dark": "tn_red",    "light": "tn_red" },
    "diffContext":         { "dark": "tn_fg_dark","light": "tn_fg_dark" },
    "diffHunkHeader":      { "dark": "tn_fg_dark","light": "tn_fg_dark" },
    "diffHighlightAdded":  { "dark": "tn_green",  "light": "tn_green" },
    "diffHighlightRemoved":{ "dark": "tn_red",    "light": "tn_red" },
    "diffAddedBg":         { "dark": "tn_bg_panel","light": "tn_bg_panel" },
    "diffRemovedBg":       { "dark": "tn_bg_panel","light": "tn_bg_panel" },
    "diffContextBg":       "none",
    "diffLineNumber":      { "dark": "tn_border",  "light": "tn_border" },
    "diffAddedLineNumberBg":   { "dark": "tn_bg_panel","light": "tn_bg_panel" },
    "diffRemovedLineNumberBg": { "dark": "tn_bg_panel","light": "tn_bg_panel" },
    "markdownText": { "dark": "tn_fg", "light": "tn_fg_dark" },
    "markdownHeading":        { "dark": "tn_blue",    "light": "tn_blue_dark" },
    "markdownLink":           { "dark": "tn_magenta", "light": "tn_purple" },
    "markdownLinkText":       { "dark": "tn_cyan",    "light": "tn_teal" },
    "markdownCode":           { "dark": "tn_green",   "light": "tn_green" },
    "markdownBlockQuote":     { "dark": "tn_fg_dark", "light": "tn_fg_dark" },
    "markdownEmph":           { "dark": "tn_orange",  "light": "tn_orange" },
    "markdownStrong":         { "dark": "tn_yellow",  "light": "tn_yellow" },
    "markdownHorizontalRule": { "dark": "tn_border",  "light": "tn_border" },
    "markdownListItem":       { "dark": "tn_blue",    "light": "tn_blue_dark" },
    "markdownListEnumeration":{ "dark": "tn_cyan",    "light": "tn_teal" },
    "markdownImage":          { "dark": "tn_magenta", "light": "tn_purple" },
    "markdownImageText":      { "dark": "tn_cyan",    "light": "tn_teal" },
    "markdownCodeBlock": { "dark": "tn_fg", "light": "tn_fg" },
    "syntaxComment":    { "dark": "tn_fg_dark", "light": "tn_fg_dark" },
    "syntaxKeyword":    { "dark": "tn_magenta", "light": "tn_purple" },
    "syntaxFunction":   { "dark": "tn_blue",    "light": "tn_blue_dark" },
    "syntaxVariable":   { "dark": "tn_cyan",    "light": "tn_teal" },
    "syntaxString":     { "dark": "tn_green",   "light": "tn_green" },
    "syntaxNumber":     { "dark": "tn_orange",  "light": "tn_orange" },
    "syntaxType":       { "dark": "tn_yellow",  "light": "tn_yellow" },
    "syntaxOperator":   { "dark": "tn_magenta", "light": "tn_purple" },
"syntaxPunctuation":{ "dark": "tn_fg", "light": "tn_fg" }
  }
}
